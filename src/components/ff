async function uploadFileFromVercel(file, notes = "") {
  const formData = new FormData();
  formData.append("files", file);
  formData.append("notes", notes);

  try {
    const response = await fetch("https://ais-dev-gjrx2a6tugveeqc7qhlfxe-411638771549.asia-east1.run.app/api/upload", {
      method: "POST",
      body: formData
    });
    
    const result = await response.json();
    alert("File uploaded successfully!");
    return result;
  } catch (error) {
    console.error("Upload failed:", error);
  }
}
